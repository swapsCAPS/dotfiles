#!/bin/bash

alias dirs="dirs -v"
alias ls="ls -lh --color=auto"
alias la="ls -lah --color=auto"
alias :q="exit"
alias gdc="git diff --cached"
alias fuh="kill -9"
alias glog="git log --oneline --decorate --graph --remotes --branches --tags"
alias k="kubectl"
alias kx="kubectx"
alias kn="kubens"
alias ripgrep="rg"

klogapp() {
  kubectl logs --prefix -f --tail 1000 --max-log-requests=50 -l app="$1" -c "$2"
}

alias secret_decode="jq '.data | map_values(. | @base64d)'"

if type nvim >/dev/null 2>/dev/null; then
  alias vim="nvim"
  alias vimdiff="nvim -d"
  export EDITOR="nvim"
fi

## FZF
export FZF_DEFAULT_COMMAND="fd --exclude node_modules --exclude .git"
export FZF_DEFAULT_OPTS="--layout=reverse --info=inline"
